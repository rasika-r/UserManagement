{
  "info": {
    "_postman_id": "user-management-api-collection",
    "name": "User Management API with Authentication",
    "description": "Collection for testing User Management API endpoints with Bearer token authentication for TechHive Solutions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "valid_test_token_12345",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer valid_test_token_12345",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5297/api/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5297",
              "path": ["api", "users"]
            },
            "description": "Retrieve a list of all users. Requires valid Bearer token."
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer valid_test_token_12345",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5297/api/users/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5297",
              "path": ["api", "users", "1"]
            },
            "description": "Retrieve a specific user by their ID. Requires valid Bearer token."
          },
          "response": []
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer valid_test_token_12345",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@techhive.com\",\n  \"department\": \"Engineering\"\n}"
            },
            "url": {
              "raw": "http://localhost:5297/api/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5297",
              "path": ["api", "users"]
            },
            "description": "Create a new user record. Requires valid Bearer token."
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer valid_test_token_12345",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"email\": \"john.smith@techhive.com\",\n  \"department\": \"Engineering\"\n}"
            },
            "url": {
              "raw": "http://localhost:5297/api/users/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5297",
              "path": ["api", "users", "1"]
            },
            "description": "Update an existing user's details. Requires valid Bearer token."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer valid_test_token_12345",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5297/api/users/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5297",
              "path": ["api", "users", "1"]
            },
            "description": "Delete a user by their ID. Requires valid Bearer token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication Tests",
      "item": [
        {
          "name": "Request WITHOUT Token (401 Error)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5297/api/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5297",
              "path": ["api", "users"]
            },
            "description": "This request will fail with 401 Unauthorized because no Authorization header is provided."
          },
          "response": []
        },
        {
          "name": "Request with Invalid Token (401 Error)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer short",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5297/api/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5297",
              "path": ["api", "users"]
            },
            "description": "This request will fail with 401 Unauthorized because the token is too short (must be at least 10 characters)."
          },
          "response": []
        },
        {
          "name": "Request with Invalid Bearer Format (401 Error)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "InvalidFormat some_token",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5297/api/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5297",
              "path": ["api", "users"]
            },
            "description": "This request will fail with 401 Unauthorized because the token format is invalid (must start with 'Bearer ')."
          },
          "response": []
        }
      ]
    },
